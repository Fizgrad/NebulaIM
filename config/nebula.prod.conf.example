# NebulaIM single-node production example.
# Copy to /etc/nebulaim/nebula.conf and replace every CHANGE_ME value.

server.host=127.0.0.1
server.port=9000

log.level=INFO
log.console=true
log.file=/var/log/nebulaim/nebula.log

thread.worker_num=4

gateway.id=gateway-1
gateway.tcp.host=127.0.0.1
gateway.tcp.port=9000
gateway.tcp.worker_threads=4
gateway.rpc_worker_threads=4
gateway.rpc_max_queue_size=10000
gateway.heartbeat_timeout_ms=30000
gateway.online_ttl_seconds=60
gateway.max_packet_body_length=1048576
gateway.rpc.host=127.0.0.1
gateway.rpc.port=50055
gateway.tls.enabled=false
gateway.tls.cert_path=/etc/nebulaim/tls/gateway.crt
gateway.tls.key_path=/etc/nebulaim/tls/gateway.key
gateway.tls.ca_cert_path=
gateway.tls.require_client_auth=false

# OpenTelemetry OTLP/HTTP tracing. Enable when Jaeger/OTel Collector is running.
trace.enabled=false
trace.service_name=nebulaim
trace.otlp_endpoint=http://127.0.0.1:4318/v1/traces
trace.export_timeout_ms=2000
trace.batch_size=64
trace.flush_interval_ms=1000
trace.max_queue_size=4096

user_service.host=127.0.0.1
user_service.port=50051

relation_service.host=127.0.0.1
relation_service.port=50053

conversation_service.host=127.0.0.1
conversation_service.port=50056

admin_service.host=127.0.0.1
admin_service.port=50057
# Format: name:sha256:token_sha256_hex:scope1,scope2
admin_service.admin_tokens=ops:sha256:CHANGE_ME_SHA256:health,stats,outbox,kafka,cleanup
admin.cleanup.outbox_published_retention_ms=604800000
admin.cleanup.offline_delivered_retention_ms=604800000
admin.cleanup.friend_request_retention_ms=2592000000
admin.cleanup.message_receipt_retention_ms=7776000000
admin.cleanup.batch_size=1000

message_service.host=127.0.0.1
message_service.port=50052
message.node_id=1
message.max_content_length=4096
message.dedup_ttl_seconds=86400
message.offline_pull_limit=100
message.recall_window_seconds=120

outbox.enabled=true
outbox.worker_interval_ms=1000
outbox.batch_size=100
outbox.max_retry_count=5
outbox.retry_backoff_ms=1000
outbox.claim_lease_ms=30000

push_service.host=127.0.0.1
push_service.port=50054
push_service.worker_num=1
push_service.poll_timeout_ms=1000
push_service.max_retry_count=3
push_service.retry_ttl_seconds=86400
push_service.skip_sender_for_group=true

rate_limit.enabled=true
rate_limit.login_per_minute=20
rate_limit.message_per_second=10
rate_limit.connection_packet_per_second=50

circuit_breaker.failure_threshold=5
circuit_breaker.open_timeout_ms=30000

# For a single host with loopback-only internal RPC, plaintext gRPC is acceptable
# behind host firewall rules. Enable TLS/mTLS if RPC ports leave loopback.
grpc.tls.enabled=false
grpc.tls.ca_cert_path=
grpc.tls.server_cert_path=
grpc.tls.server_key_path=
grpc.tls.client_cert_path=
grpc.tls.client_key_path=
grpc.tls.require_client_auth=false
grpc.tls.target_name_override=

gateway.default_id=gateway-1
gateway.gateway-1.addr=127.0.0.1:50055

user_service.addr=127.0.0.1:50051
message_service.addr=127.0.0.1:50052
relation_service.addr=127.0.0.1:50053
conversation_service.addr=127.0.0.1:50056
push_service.addr=127.0.0.1:50054
admin_service.addr=127.0.0.1:50057

auth.token_ttl_seconds=604800
auth.password_min_length=8

mysql.host=127.0.0.1
mysql.port=3306
mysql.user=nebula
mysql.password=CHANGE_ME_MYSQL_PASSWORD
mysql.database=nebula_im
mysql.pool_size=8

redis.host=127.0.0.1
redis.port=6379
redis.timeout_ms=3000
redis.password=CHANGE_ME_REDIS_PASSWORD

kafka.brokers=127.0.0.1:9092
kafka.producer.client_id=nebula-message-service
kafka.consumer.group_id=nebula-consumer
kafka.consumer.client_id=nebula-consumer-client
kafka.consumer.enable_auto_commit=false
kafka.topic.single=nebula.message.single
kafka.topic.group=nebula.message.group
kafka.topic.offline=nebula.message.offline
kafka.topic.retry=nebula.message.retry
kafka.topic.dlq=nebula.message.dlq
